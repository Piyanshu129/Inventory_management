# Inventory Agent Environment Variables
# Copy this file to .env and fill in your values

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Option A: OpenRouter (cloud, recommended)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen-2.5-72b-instruct
LLM_API_KEY=sk-or-your-openrouter-key-here

# Option B: Local LLM server (Ollama / LM Studio / vLLM)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b
# LLM_API_KEY=none

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Agent Settings ────────────────────────────────────────────────────────────
MEMORY_WINDOW=10    # Conversation turns to keep in context
RAG_TOP_K=5         # Top-k results for semantic search

# ── LLM Generation ────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024
